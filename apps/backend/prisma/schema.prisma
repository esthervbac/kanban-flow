datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String // Para o sistema de autenticação que faremos depois
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  boards    Board[] // Relacionamento: Um usuário pode ser dono de vários quadros
  cards     Card[] // Relacionamento: Um usuário pode estar atribuído a vários cards
}

model Board {
  id        String   @id @default(uuid())
  title     String
  ownerId   String
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  columns   Column[] // Relacionamento: Um quadro tem várias colunas
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Column {
  id        String   @id @default(uuid())
  title     String
  order     Int // Posição da coluna no quadro (0, 1, 2...)
  boardId   String
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards     Card[] // Relacionamento: Uma coluna tem vários cards
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Card {
  id          String   @id @default(uuid())
  title       String
  description String?  @db.Text
  order       Int // Posição do card dentro da coluna (0, 1, 2...)
  columnId    String
  column      Column   @relation(fields: [columnId], references: [id], onDelete: Cascade)
  users       User[] // Relacionamento Muitos-para-Muitos: Vários usuários podem estar no mesmo card
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}